# Qdrant Index Configuration
# This file is shared between sentinel.py and MCP server
# CRITICAL: Embeddings configuration MUST match between sentinel and MCP
# to ensure vector search queries work correctly

[qdrant]
# Qdrant server URL (use 127.0.0.1 instead of localhost to avoid Windows WSL2 IPv6 relay bug
url = "http://127.0.0.1:6333"

[embeddings]
# Embedding API configuration - MUST be identical in sentinel.py and MCP server
# Used by sentinel.py to generate embeddings during indexing
# Used by MCP server to generate embeddings for search queries
#
# NOTE: All embedding settings can be configured via environment variables in .env:
#   EMBEDDING_PROVIDER, EMBEDDING_BASE_URL, EMBEDDING_MODEL_NAME, EMBEDDING_DIMENSION, EMBEDDING_API_KEY_ENV
# Environment variables override these TOML values. This section is optional if .env is configured.
#
# Supported providers:
#   "openai_compatible" - OpenAI API, Alibaba DashScope, any OpenAI-compatible endpoint
#   "byteplus_ark"      - BytePlus Volcengine Ark API (OpenAI-compatible)
#   "alibaba" / "dashscope" - Convenience aliases for DashScope
#   "byteplus"          - Convenience alias for BytePlus Ark
# provider = "openai_compatible"
# base_url = "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
# model_name = "text-embedding-v4"
# dimension = 1024
# api_key_env_var = "EMBEDDING_API_KEY"

[openviking]
# OpenViking CLI configuration
# OpenViking does NOT use embeddings - it stores original content
# and provides context layers (L0/L1/L2) for retrieved chunks
cli_path = "ov"
enabled = true

[paths]
# File system paths
data_root = "."
state_db = "sentinel_state.db"
