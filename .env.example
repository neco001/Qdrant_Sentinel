# Qdrant Configuration
QDRANT_URL=http://127.0.0.1:6333

# Embedding Configuration (DashScope / ModelArk / OpenAI-compatible)
# All embedding config is set via environment variables
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_DIMENSION=1024

# OpenViking Server Configuration (Auto-start with PM2)
OPEN_VIKING_ENABLED=true
OPEN_VIKING_SERVER_PATH=ov
